<script>
  if (typeof window !== "undefined") {
    let cursorEffect: any;
    let observer: MutationObserver;
    let debounceTimer: ReturnType<typeof setTimeout>;

    const getThemeColors = () => {
      const rootStyle = getComputedStyle(document.documentElement);
      const hue = rootStyle.getPropertyValue("--hue").trim() || "255";
      // 使用与主题一致的 oklch 色彩空间
      const primary   = `oklch(0.70 0.14 ${hue})`;
      const secondary = `oklch(0.80 0.10 ${hue})`;
      const light     = `oklch(0.90 0.06 ${hue})`;
      return [primary, secondary, light];
    };

    import("cursor-effects").then(({ fairyDustCursor }) => {

      const rebuild = () => {
        if (cursorEffect && typeof cursorEffect.destroy === "function") {
          cursorEffect.destroy();
        }
        const colors = getThemeColors();
        cursorEffect = new fairyDustCursor({ colors });
      };

      // 防抖：拖动滑块时不频繁重建，停止拖动 150ms 后才重建
      const debouncedRebuild = () => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(rebuild, 150);
      };

      // 初始化
      rebuild();

      // 监听 --hue 变化
      observer = new MutationObserver((mutations) => {
        for (const mutation of mutations) {
          if (mutation.type === "attributes" && mutation.attributeName === "style") {
            debouncedRebuild();
          }
        }
      });

      observer.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ["style"]
      });

      document.addEventListener('astro:after-swap', rebuild);

      window.addEventListener("beforeunload", () => {
        clearTimeout(debounceTimer);
        observer?.disconnect();
        cursorEffect?.destroy?.();
      });
    });
  }
</script>
