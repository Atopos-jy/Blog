---
import { Icon } from "astro-icon/components";

import { profileConfig } from "@/config";
import { getAnalyticsConfig } from "@utils/analytics";
import { url } from "@utils/url";
import { i18n } from "@i18n/translation";
import I18nKey from "@i18n/i18nKey";
import ImageWrapper from "@/components/common/imageWrapper.astro";


const { enabled: analyticsEnabled, platform, baseUrl, apiKey, websiteId } = getAnalyticsConfig();

interface Props {
    class?: string;
    style?: string;
    side?: string;
}
const { class: className, style, side = "default" } = Astro.props;
const id = `profile-${side}`;
---

<div id={id} data-swup-persist={id} class:list={["card-base p-3", className]}>
    <a aria-label="Go to About Page" href={url('/about/')}
       class="group block relative mx-auto mt-1 lg:mx-0 lg:mt-0 mb-3
       max-w-48 lg:max-w-none overflow-hidden rounded-xl active:scale-95">
        <div class="absolute transition pointer-events-none group-hover:bg-black/30 group-active:bg-black/50
        w-full h-full z-50 flex items-center justify-center">
            <Icon name="fa6-regular:address-card"
                  class="transition opacity-0 scale-90 group-hover:scale-100 group-hover:opacity-100 text-white text-5xl">
            </Icon>
        </div>
        <ImageWrapper src={profileConfig.avatar || ""} alt="Profile Image of the Author" class="mx-auto lg:w-full h-full lg:mt-0" loading="eager"></ImageWrapper>
    </a>
    <div class="px-2">
        <div class="font-bold text-xl text-center mb-1 dark:text-neutral-50 transition">{profileConfig.name}</div>
        <div class="h-1 w-5 bg-(--primary) mx-auto rounded-full mb-2 transition"></div>
        <div class="text-center text-neutral-400 mb-2.5 transition">{profileConfig.bio}</div>
        <div class="flex gap-2 justify-center mb-1">
            {profileConfig.links.map(item => {
                const isSingleLink = profileConfig.links.length === 1;
                const action = item.action ?? "link";
                const inlineColor = item.color ? `color: ${item.color};` : undefined;
                const copyPayload = item.copyValue ?? "";
                const copyHint = item.copyHint ?? `${item.name} copied`;

                if (action === "copy") {
                    return (
                        <button
                            type="button"
                            aria-label={`Copy ${item.name}`}
                            title={copyHint}
                            data-profile-copy-btn
                            data-copy-value={copyPayload}
                            data-copy-hint={copyHint}
                            class:list={[
                                "profile-copy-btn btn-regular rounded-lg active:scale-90 text-(--btn-content)!",
                                isSingleLink ? "h-10 gap-2 px-3 font-bold active:scale-95" : "h-10 w-10"
                            ]}
                        >
                            <Icon name={item.icon} class="text-[1.5rem] text-(--btn-content)!" style={inlineColor}></Icon>
                            {isSingleLink && item.name}
                        </button>
                    );
                }

                return (
                    <a
                        rel="me"
                        aria-label={item.name}
                        href={item.url ?? "#"}
                        target="_blank"
                        class:list={[
                            "btn-regular rounded-lg active:scale-90 text-(--btn-content)!",
                            isSingleLink ? "h-10 gap-2 px-3 font-bold active:scale-95" : "h-10 w-10"
                        ]}
                    >
                        <Icon name={item.icon} class="text-[1.5rem] text-(--btn-content)!" style={inlineColor}></Icon>
                        {isSingleLink && item.name}
                    </a>
                );
            })}
        </div>
        {analyticsEnabled && (
            <hr class="my-2 border-t border-dashed border-gray-300 dark:border-gray-700" />
            <div class="text-sm text-gray-500 mt-2 text-center site-stats-container"
                 data-analytics-base-url={baseUrl}
                 data-analytics-api-key={apiKey}
                 data-analytics-website-id={websiteId}
                 data-i18n-views={i18n(I18nKey.pageViews)}
                 data-i18n-visitors={i18n(I18nKey.visitors)}
                 data-i18n-error={i18n(I18nKey.statsError)}
            >
                <Icon name="fa6-solid:eye" class="inline-block mr-1 text-gray-400 text-sm align-middle" />
                <span class="site-stats-display">{i18n(I18nKey.statsLoading)}</span>
            </div>
        )}
    </div>
</div>

<style>
    .profile-copy-btn {
        position: relative;
    }

    .profile-copy-btn.copied::after {
        content: attr(data-copy-feedback);
        position: absolute;
        left: 50%;
        top: -0.45rem;
        transform: translate(-50%, -100%);
        font-size: 0.72rem;
        line-height: 1;
        white-space: nowrap;
        padding: 0.25rem 0.5rem;
        border-radius: 0.45rem;
        background: color-mix(in oklab, var(--btn-regular-bg) 78%, black);
        color: var(--btn-content);
        box-shadow: 0 2px 10px rgb(0 0 0 / 18%);
        pointer-events: none;
        z-index: 1;
    }
</style>

{analyticsEnabled && (
    <script>
        import { initAnalyticsStats } from "@utils/analytics";
        import "@/plugins/umami-share";

        initAnalyticsStats(".site-stats-container", ".site-stats-display", "umami", false);
        document.addEventListener('astro:page-load', () => {
            initAnalyticsStats(".site-stats-container", ".site-stats-display", "umami", false);
        });
    </script>
)}

<script is:inline>
  // 使用匿名函数包裹，避免污染全局变量，同时确保立即执行
  (() => {
    const handleCopyAction = async (e) => {
      // 1. 寻找点击链条中是否包含目标按钮
      const btn = e.target.closest("[data-profile-copy-btn]");
      
      if (!btn) return;

      // 阻止默认行为（如果是放在 a 标签里的按钮）
      e.preventDefault();


      const textToCopy = btn.getAttribute("data-copy-value") || "";
      const feedbackText = btn.getAttribute("data-copy-hint") || "Done!";

      if (!textToCopy) {
        return;
      }

      try {
        // 执行写入剪贴板
        await navigator.clipboard.writeText(textToCopy);
        
        // UI 反馈
        btn.classList.add("copied");
        btn.setAttribute("data-copy-feedback", feedbackText);
        
        // 1.3秒后移除动画状态
        setTimeout(() => {
          btn.classList.remove("copied");
        }, 1300);

      } catch (err) {
        // 兜底方案：万一 Clipboard API 被禁用
        console.error("写入失败，尝试备用方案...", err);
        const textArea = document.createElement("textarea");
        textArea.value = textToCopy;
        document.body.appendChild(textArea);
        textArea.select();
        document.execCommand("copy");
        document.body.removeChild(textArea);
        
        btn.classList.add("copied");
        setTimeout(() => btn.classList.remove("copied"), 1300);
      }
    };

    // 绑定到 window 对象，这样不管 Swup 怎么刷新页面内容，
    // 只要 window 不销毁，监听就一直存在（事件委托模式）
    // 先移除旧监听防止在开发环境下热更新导致的重复绑定
    window.removeEventListener("click", handleCopyAction);
    window.addEventListener("click", handleCopyAction);

  })();
</script>